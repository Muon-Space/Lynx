<!DOCTYPE html>
<html dir="ltr">

  <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta http-equiv="X-UA-Compatible" content="ie=edge">
      <meta name="csrf-token" content="<%= Plug.CSRFProtection.get_csrf_token() %>">

      <!-- Favicon -->
      <link rel="icon" href="<%= ~p"/images/favicon.png" %>" />
      <meta name="msapplication-TileColor" content="#0010f7">
      <meta name="theme-color" content="#ffffff">

      <!-- Font -->
      <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

      <!-- Plugin -->
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/plugin/swiper-bundle.min.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/icons/iconly/index.min.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/icons/remix-icon/index.min.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/bootstrap.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/colors.css" %>">

      <!-- Base -->
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/base/typography.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/base/base.css" %>">

      <!-- Theme -->
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/theme/colors-dark.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/theme/theme-dark.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/custom-rtl.css" %>">

      <!-- Layouts -->
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/layouts/sider.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/layouts/header.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/layouts/page-content.css" %>">
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/components.css" %>">

      <!-- Horizontal -->
      <link rel="stylesheet" type="text/css" href="<%= ~p"/theme/app/css/layouts/horizontal-menu.css" %>">

      <title><%= assigns[:page_title] || "Lynx - A Fast, Secure and Reliable Terraform Backend" %></title>
  </head>

  <body class="horizontal-active">
      <%= @inner_content %>

      <!-- Plugin -->
      <script src="https://cdnjs.cloudflare.com/ajax/libs/vue/2.7.10/vue.min.js" integrity="sha384-RyJao284s+5Z7X0QVo5uKszbojnincJ/kOrcTIqKC/Pi8EVOF6BFTE9xw52unBjU" crossorigin="anonymous"></script>
      <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.3.4/axios.min.js" integrity="sha384-es0HiLUGcrrPhNqo0EwhhpDeHORxK3d+EVccCFO0RFLRxu7d77SO3Y1/rR2c/Vdl" crossorigin="anonymous"></script>

      <script src="<%= ~p"/theme/app/js/plugin/jquery.min.js" %>"></script>
      <script src="<%= ~p"/theme/app/js/plugin/bootstrap.bundle.min.js" %>"></script>
      <script src="<%= ~p"/theme/app/js/plugin/swiper-bundle.min.js" %>"></script>
      <script src="<%= ~p"/theme/app/js/plugin/jquery.mask.min.js" %>"></script>
      <script src="<%= ~p"/theme/app/js/plugin/autocomplete.min.js" %>"></script>
      <script src="<%= ~p"/theme/app/js/plugin/moment.min.js" %>"></script>

      <!-- Layouts -->
      <script src="<%= ~p"/theme/app/js/layouts/header-search.js" %>"></script>
      <script src="<%= ~p"/theme/app/js/layouts/sider.js" %>"></script>

      <!-- Base -->
      <script src="<%= ~p"/theme/app/js/base/index.js" %>"></script>

      <!-- Horizontal -->
      <script src="<%= ~p"/theme/app/js/layouts/horizontal-menu.js" %>"></script>

      <!-- Backend -->
      <script src="<%= ~p"/theme/app/backend.js" %>"></script>
  </body>
</html>