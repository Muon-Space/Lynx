APP_HOST=localhost
APP_HTTP_SCHEMA=http

DB_USERNAME=lynx
DB_PASSWORD=lynx
DB_HOSTNAME=localhost
DB_DATABASE=lynx_dev
DB_PORT=5432
DB_SSL=off
DB_CA_CERTFILE_PATH=

# Auth
AUTH_PASSWORD_ENABLED=true
AUTH_SSO_ENABLED=false
# Emergency override: forces password login even if disabled in Settings UI
FORCE_PASSWORD_LOGIN=false

# SSO - General
SSO_PROTOCOL=oidc
SSO_LOGIN_LABEL=SSO
SSO_JIT_ENABLED=true

# SSO - OIDC (when SSO_PROTOCOL=oidc)
SSO_ISSUER=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# SSO - SAML (when SSO_PROTOCOL=saml)
SSO_SAML_IDP_SSO_URL=
SSO_SAML_IDP_ISSUER=
SSO_SAML_IDP_CERT=
SSO_SAML_IDP_METADATA_URL=
SSO_SAML_SP_ENTITY_ID=
SSO_SAML_SIGN_REQUESTS=false
# SP cert/key for signed requests: provide either file paths OR base64-encoded values
SSO_SAML_SP_CERTFILE=
SSO_SAML_SP_KEYFILE=
SSO_SAML_SP_CERT_BASE64=
SSO_SAML_SP_KEY_BASE64=

# SCIM 2.0
SCIM_ENABLED=false

MIX_ENV=prod
